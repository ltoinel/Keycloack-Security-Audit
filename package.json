{
  "name": "keycloak-security-audit",
  "version": "0.1.0",
  "description": "Security audit tool for Keycloak servers (configuration analysis via the Admin API + external black-box tests).",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ltoinel/Keycloack-Security-Audit.git"
  },
  "homepage": "https://github.com/ltoinel/Keycloack-Security-Audit#readme",
  "bugs": {
    "url": "https://github.com/ltoinel/Keycloack-Security-Audit/issues"
  },
  "license": "MIT",
  "bin": {
    "keycloak-security-audit": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "audit": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "undici": "^6.19.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
