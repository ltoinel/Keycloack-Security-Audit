# --- Keycloak target --------------------------------------------------------
# Server base URL (no trailing slash). E.g. https://auth.mydomain.com
KC_BASE_URL=https://localhost:8443

# Realm to audit
KC_REALM=master

# Keycloak version (optional) — used for CVE correlation when passive detection fails
# KC_VERSION=26.0.5

# --- Admin API authentication (white-box mode) ------------------------------
# Two possible modes. Fill in ONE of them.

# Mode 1: "password" grant with an admin account of the master realm
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=
# Client used for authentication (default admin-cli)
KC_ADMIN_CLIENT_ID=admin-cli

# Mode 2: "client_credentials" grant with a service account (recommended)
# KC_ADMIN_CLIENT_ID=audit-service
# KC_ADMIN_CLIENT_SECRET=

# --- Options ----------------------------------------------------------------
# Verify TLS certificates (set to false only for an internal lab)
KC_TLS_VERIFY=true
